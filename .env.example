# Supabase Configuration
# Copy this file to .env.local and fill in your actual values

# Your Supabase project URL (find this in your Supabase project settings)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key (find this in your Supabase project settings > API)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Codacy Project Token (optional - for code quality analysis)
CODACY_PROJECT_TOKEN=your-codacy-token-here
